# Crypto Bot Secrets — copy to .env and fill in real values. Never commit .env.

# Gmail SMTP (generate App Password at https://myaccount.google.com/apppasswords)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# WEEX API (or set these in your system environment)
# WEEX_API_KEY=
# WEEX_API_SECRET=
# WEEX_API_PASSPHRASE=

# ─── Shared trading kill-switch ───────────────────────────────────────────
# Set to "false" to pause all NEW entries across both bots. Existing positions
# still run their SL/TP. Useful for maintenance or volatile market regimes.
TRADING_ENABLED=true

# ─── Whale-bot debugging ──────────────────────────────────────────────────
# When true, whale bot dumps extra signal diagnostics to logs each cycle.
WHALE_DEBUG_DUMP=false

# ─── Whale-bot pause flag ─────────────────────────────────────────────────
# Set to "true" to stop the whale bot from opening NEW positions. Existing
# positions still manage to exit. Currently true per peer-review consensus
# (May 2026) — re-enable once SL widening + trend filter are validated.
WHALE_PAUSED=true

# ─── Funding-fade bot pause flag ──────────────────────────────────────────
# Set to "true" to stop the funding-fade bot from opening NEW positions.
# Default false — bot trades when conditions are met.
FUNDING_PAUSED=false

# Coinglass API key (DEPRECATED — bot now uses HL fundingHistory which is
# free + public, no key needed). Kept for backward-compat in case you want
# to swap providers later.
# COINGLASS_API_KEY=
