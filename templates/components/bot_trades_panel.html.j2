{# J.4: Shared per-bot closed-trades panel. Caller passes `bot_trades` list. #}
{% if bot_trades %}
<section class="bot-trades" aria-label="Closed trades for this bot">
  <h2 class="bot-trades__heading">Recent closed trades ({{ bot_trades|length }})</h2>
  {# Tier 2.2: data-sortable = generic click-to-sort headers + sticky thead #}
  <table class="regime-table" data-sortable>
    <thead>
      <tr>
        <th scope="col">When</th>
        <th scope="col">Symbol</th>
        <th scope="col">Dir</th>
        <th scope="col">Entry</th>
        <th scope="col">Exit</th>
        <th scope="col">PnL</th>
        <th scope="col">Result</th>
        <th scope="col">Exit reason</th>
      </tr>
    </thead>
    <tbody>
      {% for t in bot_trades %}
      <tr>
        <td>{{ t.date_closed }}</td>
        <td>{{ t.symbol }}</td>
        <td>{{ t.direction }}</td>
        <td class="num">{{ t.entry_price }}</td>
        <td class="num">{{ t.exit_price }}</td>
        <td class="num {{ t.result_class }}">{{ t.net_pnl_display }}</td>
        <td>{{ t.result }}</td>
        <td>{{ t.exit_reason }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% else %}
<section class="bot-trades" aria-label="Closed trades for this bot">
  <h2 class="bot-trades__heading">Recent closed trades</h2>
  {# Tier 2.3: standardized empty state #}
  <div class="empty-state">
    <span class="empty-state__glyph" aria-hidden="true">⌀</span>
    <span class="empty-state__msg">No closed trades yet</span>
    <span class="empty-state__hint">rows appear after the first paper exit — check the Revalidation pipeline panel for this bot's stage</span>
  </div>
</section>
{% endif %}
