<h1 class="tab-heading">Overview</h1>

{# Tier 3.A Mission Control ordering: (1) am I safe? (2) what changed?
   (3) bot status + why-quiet — then the analysis panels. #}

{% include "components/kill_switch_panel.html.j2" %}

{% include "components/mission_control.html.j2" %}

{% include "components/gate_tracker_panel.html.j2" %}

{% include "components/exit_reason_panel.html.j2" %}

<section class="portfolio-strip" aria-label="Portfolio totals">
  <div class="portfolio-strip__cell">
    <span class="portfolio-strip__label">NET PnL · all bots</span>
    <span class="portfolio-strip__value
                {% if portfolio.net_pnl > 0 %}is-up{% elif portfolio.net_pnl < 0 %}is-down{% endif %}">
      {{ portfolio.net_pnl_display }}
    </span>
    {% if portfolio.spark_svg %}
    <div class="portfolio-strip__spark" aria-hidden="true">{{ portfolio.spark_svg|safe }}</div>
    {% endif %}
  </div>
  <div class="portfolio-strip__cell">
    <span class="portfolio-strip__label">CLOSED</span>
    <span class="portfolio-strip__value">{{ portfolio.closed_count }}</span>
  </div>
  <div class="portfolio-strip__cell">
    <span class="portfolio-strip__label">OPEN</span>
    <span class="portfolio-strip__value">{{ portfolio.open_count }}</span>
  </div>
  <div class="portfolio-strip__cell">
    <span class="portfolio-strip__label">WIN RATE</span>
    <span class="portfolio-strip__value">{{ portfolio.win_rate_display }}</span>
  </div>
</section>

<section class="risk-metrics" aria-label="Risk-adjusted performance">
  <h2 class="risk-metrics__heading">Risk metrics</h2>
  <div class="risk-metrics__grid">
    <div class="risk-cell">
      <span class="risk-cell__label">Sortino</span>
      <span class="risk-cell__value">{{ risk_metrics.sortino_display }}</span>
      <span class="risk-cell__note">downside-only</span>
    </div>
    <div class="risk-cell">
      <span class="risk-cell__label">Calmar · 90d</span>
      <span class="risk-cell__value">{{ risk_metrics.calmar_display }}</span>
      <span class="risk-cell__note">return / max DD</span>
    </div>
    <div class="risk-cell">
      <span class="risk-cell__label">Ulcer Index</span>
      <span class="risk-cell__value">{{ risk_metrics.ulcer_display }}</span>
      <span class="risk-cell__note">drawdown duration</span>
    </div>
    <div class="risk-cell">
      <span class="risk-cell__label">Max DD</span>
      <span class="risk-cell__value">{{ risk_metrics.max_dd_display }}</span>
      <span class="risk-cell__note">peak-to-trough</span>
    </div>
    <div class="risk-cell">
      <span class="risk-cell__label">Time underwater</span>
      <span class="risk-cell__value">{{ risk_metrics.time_underwater_display }}</span>
      <span class="risk-cell__note">since last peak</span>
    </div>
    <div class="risk-cell">
      <span class="risk-cell__label">Streak</span>
      <span class="risk-cell__value {{ risk_metrics.streak_class }}">{{ risk_metrics.streak_display }}</span>
      <span class="risk-cell__note">most recent run</span>
    </div>
    <div class="risk-cell">
      <span class="risk-cell__label">Recovery factor</span>
      <span class="risk-cell__value">{{ risk_metrics.recovery_display }}</span>
      <span class="risk-cell__note">profit / max DD $</span>
    </div>
  </div>
</section>

{% if regime_expectancy.has_data %}
<section class="regime-expectancy" aria-label="Per-regime expectancy">
  <h2 class="regime-expectancy__heading">Per-regime expectancy</h2>
  <table class="regime-table">
    <thead>
      <tr>
        <th scope="col">Regime</th>
        <th scope="col">Trades</th>
        <th scope="col">Expectancy</th>
        <th scope="col">Win rate</th>
        <th scope="col">Total PnL</th>
      </tr>
    </thead>
    <tbody>
      {% for row in regime_expectancy.rows %}
      <tr>
        <td>{{ row.regime }}</td>
        <td class="num">{{ row.count }}</td>
        <td class="num">{{ row.expectancy_display }}</td>
        <td class="num">{{ row.win_rate_display }}</td>
        <td class="num">{{ row.total_pnl_display }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

<div class="chart-row">
  <section class="chart-panel equity-curve" aria-label="Cumulative PnL over 90 days">
    <header class="chart-panel__head">
      <h2 class="chart-panel__title">Cumulative P/L · 90 days</h2>
      <ul class="chart-legend">
        <li class="chart-legend__item"><span class="chart-legend__dot chart-legend__dot--aggregate"></span>Portfolio</li>
        <li class="chart-legend__item"><span class="chart-legend__dot chart-legend__dot--momentum"></span>Momentum</li>
        <li class="chart-legend__item"><span class="chart-legend__dot chart-legend__dot--whale"></span>Whale</li>
        <li class="chart-legend__item"><span class="chart-legend__dot chart-legend__dot--funding"></span>Funding</li>
      </ul>
    </header>
    <div class="chart-panel__svg">{{ equity_curve_svg|safe }}</div>
  </section>

  <section class="chart-panel daily-pnl" aria-label="Daily PnL over last 30 days">
    <header class="chart-panel__head">
      <h2 class="chart-panel__title">Daily P/L · 30 days</h2>
    </header>
    <div class="chart-panel__svg">{{ daily_pnl_svg|safe }}</div>
  </section>
</div>
