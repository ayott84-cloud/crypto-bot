<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <meta http-equiv="refresh" content="300">
  <title>Crypto Bots · Operator</title>
  <link rel="stylesheet" href="/static/css/tokens.css">
  <link rel="stylesheet" href="/static/css/base.css">
  <link rel="stylesheet" href="/static/css/layout.css">
  <link rel="stylesheet" href="/static/css/components.css">
</head>
<body class="app-shell">
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- J.1: Left vertical sidebar nav. Replaces the horizontal top tabs. -->
  <nav class="sidebar" role="tablist" aria-label="Dashboard sections" aria-orientation="vertical">
    <div class="sidebar__brand">
      <span class="sidebar__monogram">⌖</span>
      <span class="sidebar__brandname">crypto-bot</span>
    </div>
    <div class="sidebar__group">
      <span class="sidebar__group-label">SYSTEM</span>
      <button role="tab" aria-selected="true"  aria-current="page"
              aria-controls="tab-overview"   data-tab="overview"   class="sidebar__item active">
        <span class="sidebar__icon">⌖</span><span class="sidebar__label">Overview</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-trades"     data-tab="trades"     class="sidebar__item">
        <span class="sidebar__icon">≡</span><span class="sidebar__label">Trade Log</span>
      </button>
    </div>
    <div class="sidebar__group">
      <span class="sidebar__group-label">BOTS</span>
      <button role="tab" aria-selected="false"
              aria-controls="tab-momentum"   data-tab="momentum"   class="sidebar__item">
        <span class="sidebar__icon monogram--momentum">M</span><span class="sidebar__label">Momentum</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-whale"      data-tab="whale"      class="sidebar__item">
        <span class="sidebar__icon monogram--whale">W</span><span class="sidebar__label">Whale</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-funding"    data-tab="funding"    class="sidebar__item">
        <span class="sidebar__icon monogram--funding">F</span><span class="sidebar__label">Funding</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-breakout"   data-tab="breakout"   class="sidebar__item">
        <span class="sidebar__icon monogram--breakout">B</span><span class="sidebar__label">Breakout</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-pair"       data-tab="pair"       class="sidebar__item">
        <span class="sidebar__icon monogram--pair">P</span><span class="sidebar__label">Pair</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-reversal"   data-tab="reversal"   class="sidebar__item">
        <span class="sidebar__icon monogram--reversal">R</span><span class="sidebar__label">Reversal</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-scalp"      data-tab="scalp"      class="sidebar__item">
        <span class="sidebar__icon monogram--scalp">S</span><span class="sidebar__label">Scalp</span>
      </button>
      <button role="tab" aria-selected="false"
              aria-controls="tab-crossover"  data-tab="crossover"  class="sidebar__item">
        <span class="sidebar__icon monogram--crossover">X</span><span class="sidebar__label">Crossover</span>
      </button>
    </div>
    <div class="sidebar__group">
      <span class="sidebar__group-label">ANALYSIS</span>
      <button role="tab" aria-selected="false"
              aria-controls="tab-projection" data-tab="projection" class="sidebar__item">
        <span class="sidebar__icon">Σ</span><span class="sidebar__label">Projection</span>
      </button>
    </div>
  </nav>

  <div class="app-shell__main">
    {% include "components/colophon.html.j2" %}

    <main class="page" id="main-content">
      <section role="tabpanel" id="tab-overview"   tabindex="0">
        {% include "tabs/overview.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-trades"     tabindex="0" hidden>
        {% include "tabs/trades.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-momentum"   tabindex="0" hidden>
        {% include "tabs/momentum.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-whale"      tabindex="0" hidden>
        {% include "tabs/whale.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-funding"    tabindex="0" hidden>
        {% include "tabs/funding.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-breakout"   tabindex="0" hidden>
        {% include "tabs/breakout.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-pair"       tabindex="0" hidden>
        {% include "tabs/pair.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-reversal"   tabindex="0" hidden>
        {% include "tabs/reversal.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-scalp"      tabindex="0" hidden>
        {% include "tabs/scalp.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-crossover"  tabindex="0" hidden>
        {% include "tabs/crossover.html.j2" %}
      </section>
      <section role="tabpanel" id="tab-projection" tabindex="0" hidden>
        {% include "tabs/projection.html.j2" %}
      </section>
    </main>

    <footer class="page-foot">
      <span class="page-foot__build">Build · {{ build_sha }} · {{ build_ts }}</span>
    </footer>
  </div>

  <!-- J.2: TradingView Lightweight Charts (BSD, vendored). Loads before
       dashboard.js so chart-init code can reference `LightweightCharts`. -->
  <script src="/static/js/lightweight-charts.standalone.production.js"></script>
  <script src="/static/js/dashboard.js"></script>
</body>
</html>
